// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Users ────────────────────────────────────────────────────────────────
model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique @db.VarChar(32)
  email     String    @unique @db.VarChar(255)
  avatar    String?   @default("/avatars/default.svg") @db.VarChar(512)
  bio       String?   @default("") @db.Text
  status    String?   @default("Hey there! I am using AlpacaParty") @db.VarChar(255)
  isOnline  Boolean?  @default(false) @map("is_online")
  lastSeen  DateTime? @default(now()) @map("last_seen") @db.Timestamptz
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  sentFriendRequests     FriendRequest[]      @relation("sentRequests")
  receivedFriendRequests FriendRequest[]      @relation("receivedRequests")
  friends                Friend[]             @relation("userFriends")
  friendedBy             Friend[]             @relation("friendUsers")
  blockedUsers           BlockedUser[]        @relation("userBlocked")
  blockedBy              BlockedUser[]        @relation("blockedByUser")
  sentMessages           Message[]            @relation("sentMessages")
  receivedMessages       Message[]            @relation("receivedMessages")
  wonGames               Game[]               @relation("winner")
  gameStats              GameStat[]
  achievements           UserAchievement[]
  // dailyChallenges        UserDailyChallenge[]
  notifications          Notification[]
  posts                  Post[]
  postLikes              PostLike[]
  uploadedFiles          File[]
  alpacaFarm             AlpacaFarm?
  dataRequests           DataRequest[]
  userAuth               UserAuth?
  userStats              UserStats?
  userSettings           UserSettings?
  comments               Comment[]
  publicApi              PublicApi?

  @@map("user")
}

model UserAuth {
  id           Int     @id @default(autoincrement())
  passwordHash String? @db.VarChar(255)

  // Relations
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @unique

  @@map("user_auth")
}

model PublicApi {
  id     Int    @id @default(autoincrement())
  apiKey String @unique @map("api_key") @db.Text

  // Relations
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @unique

  @@map("public_api")
}

model UserStats {
  userId         Int       @id @map("user_id")
  xp             Int?      @default(0)
  level          Int?      @default(0)
  winStreak      Int?      @default(0) @map("win_streak")
  loginStreak    Int?      @default(0) @map("login_streak")
  lastLoginDate  DateTime? @map("last_login_date")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

model UserSettings {
  isPublic Boolean? @default(true) @map("is_public")

  // Relations
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @unique

  @@index([isPublic])
  @@map("user_settings")
}

// ── Friend Requests ──────────────────────────────────────────────────────
model FriendRequest {
  id         Int      @id @default(autoincrement())
  senderId   Int      @map("sender_id")
  receiverId Int      @map("receiver_id")
  status     String?  @default("pending") @db.VarChar(10) // Note: Prisma handles CHECK constraints via the DB, or use enums
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  sender   User @relation("sentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("receivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId])
  @@map("friend_request")
}

// ── Friends ──────────────────────────────────────────────────────────────
model Friend {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  friendId  Int      @map("friend_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user   User @relation("userFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("friendUsers", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@map("friend")
}

// ── Blocked Users ────────────────────────────────────────────────────────
model BlockedUser {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  blockedUserId Int      @map("blocked_user_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  user        User @relation("userBlocked", fields: [userId], references: [id], onDelete: Cascade)
  blockedUser User @relation("blockedByUser", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, blockedUserId])
  @@map("blocked_user")
}

// ── Chat Messages (DM) ──────────────────────────────────────────────────
model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int      @map("sender_id")
  receiverId Int      @map("receiver_id")
  content    String   @db.Text
  isRead     Boolean? @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  sender   User @relation("sentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("receivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  // Compound index for conversation queries (fetch msgs between two users)
  @@index([senderId, receiverId])
  @@map("message")
}

// ── Games ────────────────────────────────────────────────────────────────
model Game {
  id           Int       @id @default(autoincrement())
  player1Id    Int       @map("player1_id")
  player2Id    Int?      @map("player2_id")
  winnerId     Int?      @map("winner_id")
  player1Score Int?      @default(0) @map("player1_score")
  player2Score Int?      @default(0) @map("player2_score")
  status       String?   @default("waiting") @db.VarChar(20)
  gameType     String?   @default("pong") @map("game_type") @db.VarChar(30)
  gameData     Json?     @default("{}") @map("game_data")
  startedAt    DateTime? @map("started_at") @db.Timestamptz
  finishedAt   DateTime? @map("finished_at") @db.Timestamptz
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz

  winner  User? @relation("winner", fields: [winnerId], references: [id], onDelete: SetNull)

  @@index([player1Id])
  @@index([player2Id])
  @@map("game")
}

// ── Game Statistics ──────────────────────────────────────────────────────
model GameStat {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  gameType  String   @default("pong") @map("game_type") @db.VarChar(30)
  wins      Int?     @default(0)
  losses    Int?     @default(0)
  draws     Int?     @default(0)
  kills     Int?     @default(0)
  obstacles Int?     @default(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameType])
  @@index([userId])
  @@map("game_stat")
}

// ── Achievements / Badges ────────────────────────────────────────────────
model Achievement {
  id          Int     @id @default(autoincrement())
  key         String  @unique @db.VarChar(60)
  name        String  @db.VarChar(120)
  description String? @default("") @db.Text
  icon        String? @default("") @db.VarChar(512)
  xpReward    Int?    @default(0) @map("xp_reward")

  users UserAchievement[]

  @@map("achievement")
}

model UserAchievement {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  achievementId Int      @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at") @db.Timestamptz

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievement")
}

