# AlpacaParty — Environment Variables
#
# Copy to .env and fill in your values (or run `make generate-secrets`, which
# creates .env from this file with random secrets and your machine's IP/ports
# substituted in). Never commit .env to version control.

COMPOSE_PROJECT_NAME=alpacaparty

# ── Ports (single source of truth) ──────────────────────────────
# Change these and re-run `make` — nothing else hardcodes a port. The host
# reaches the app at https://<MY_IP>:${HTTPS_PORT}. API_PORT/FRONTEND_PORT/
# DB_PORT are internal service ports on the Docker network.
HTTPS_PORT=8443
HTTP_PORT=8080
API_PORT=3000
FRONTEND_PORT=5173
DB_PORT=5432

# PostgreSQL
DB_HOST=postgres
DB_NAME=alpacaparty
DB_USER=alpacapartyUser
DB_PASSWORD=

# Json Web Token
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_PUBLIC_API_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_PUBLIC_API_EXPIRES_IN=30d

# Backend
NODE_ENV=production

# Frontend
VITE_API_URL=/api

# Public API host (MY_IP + HTTPS_PORT are filled in by `make generate-secrets`)
PUBLIC_API_HOST={MY_IP}:{HTTPS_PORT}

# Frontend URL (used for HTTPS redirects)
FRONTEND_URL=https://{MY_IP}:{HTTPS_PORT}

# Cors
CORS_ORIGINS=https://{MY_IP}:{HTTPS_PORT},https://{MY_IP}.nip.io:{HTTPS_PORT}

# Groq AI (help desk)
# Up to 3 keys from console.groq.com — rotated round-robin to spread rate limits
GROQ_API_KEY1=
GROQ_API_KEY2=
GROQ_API_KEY3=

# File Uploads
UPLOAD_MAX_SIZE=10485760
